fn is_prime(n) {
    if (n < 2) {
        return 0;
    }
    let i = 2;
    @unsafe while (i * i <= n) {
        if (n % i == 0) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

let count = 0;
@unsafe for (let i = 2; i <= 10000; i = i + 1) {
    if (is_prime(i)) {
        count = count + 1;
    }
}
print(count);
