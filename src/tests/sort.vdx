let arr = [];
@unsafe for (let i = 0; i < 100; i = i + 1) {
    push(arr, 100 - i);
}
@unsafe for (let i = 0; i < 99; i = i + 1) {
    @unsafe for (let j = 0; j < 99 - i; j = j + 1) {
        if (arr[j] > arr[j + 1]) {
            let tmp = arr[j];
            arr[j] = arr[j + 1];
            arr[j + 1] = tmp;
        }
    }
}
print(arr[50]);
